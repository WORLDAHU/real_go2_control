<?xml version='1.0' encoding='utf-8'?>
<robot name="RL_single_leg_slider">
  <link name="rail_base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>
  <link name="slider_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>
  <joint name="slider_z_joint" type="prismatic">
    <origin xyz="0 0 0.35" rpy="0 0 0" />
    <parent link="rail_base" />
    <child link="slider_link" />
    <axis xyz="0 0 1" />
    <limit lower="-0.30" upper="0.60" effort="100" velocity="5" />
  </joint>
  <link name="RL_hip">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../custom_robot/meshes/RL_hip.STL" />
      </geometry>
      <material name="auto_material_10">
        <color rgba="0.79607843 0.82352941 0.93725490 1.00000000" />
      </material>
    </visual>
    <inertial>
      <origin xyz="-0.0473043 -0.0004014 -0.0000785" rpy="0 0 0" />
      <mass value="0.2903942" />
      <inertia ixx="0.0002169" ixy="0.000003" ixz="0.0000004" iyy="0.0003315" iyz="0" izz="0.000175" />
    </inertial>
  </link>
  <link name="RL_thigh">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../custom_robot/meshes/RL_thigh.STL" />
      </geometry>
      <material name="auto_material_11">
        <color rgba="0.79607843 0.82352941 0.93725490 1.00000000" />
      </material>
    </visual>
    <inertial>
      <origin xyz="-0.0028225 0.0426963 -0.0252023" rpy="0 0 0" />
      <mass value="0.5536703" />
      <inertia ixx="0.0013035" ixy="0.0000011" ixz="0.0000788" iyy="0.0015743" iyz="0.0000081" izz="0.0002945" />
    </inertial>
  </link>
  <link name="RL_calf">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../custom_robot/meshes/RL_calf.STL" />
      </geometry>
      <material name="auto_material_12">
        <color rgba="0.77647059 0.75686275 0.73725490 1.00000000" />
      </material>
    </visual>
    <inertial>
      <origin xyz="0.0095591 0.0000034 -0.0770108" rpy="0 0 0" />
      <mass value="0.0839255" />
      <inertia ixx="0.0003532" ixy="0" ixz="-0.0000119" iyy="0.0003585" iyz="0" izz="0.0000093" />
    </inertial>
  </link>
  <link name="RL_foot">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../custom_robot/meshes/RL_foot.STL" />
      </geometry>
      <material name="auto_material_13">
        <color rgba="0.79607843 0.82352941 0.93725490 1.00000000" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0.0000126 0 0.0118098" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.014796" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0011417 0 0.0103123" rpy="0 0 0" />
      <mass value="0.0083244" />
      <inertia ixx="0.0000004" ixy="0" ixz="-0.0000001" iyy="0.0000009" iyz="0" izz="0.0000008" />
    </inertial>
  </link>
  <joint name="RL_hip_joint" type="revolute">
    <parent link="slider_link" />
    <child link="RL_hip" />
    <origin xyz="0.000000 0.000000 0.002513" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-0.35" upper="0.35" effort="8" velocity="10" />
  </joint>
  <joint name="RL_thigh_joint" type="revolute">
    <parent link="RL_hip" />
    <child link="RL_thigh" />
    <origin xyz="-0.0599992 0.0203992 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-0.2" upper="1.4" effort="8" velocity="10" />
  </joint>
  <joint name="RL_calf_joint" type="revolute">
    <parent link="RL_thigh" />
    <child link="RL_calf" />
    <origin xyz="0 0.05865 -0.1940135" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-2.8" upper="-1.2" effort="8" velocity="10" />
  </joint>
  <joint name="RL_foot_joint" type="fixed">
    <parent link="RL_calf" />
    <child link="RL_foot" />
    <origin xyz="0 0 -0.21" rpy="0 0 0" />
  </joint>
</robot>